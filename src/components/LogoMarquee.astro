---
interface Logo {
  src: string;
  alt: string;
}

interface Props {
  logos: Logo[];
  speed?: number; // seconds for one complete loop
}

const { logos, speed = 30 } = Astro.props;

// Duplicate logos for seamless infinite scroll
const duplicatedLogos = [...logos, ...logos];
---

<div class="logo-marquee-container" data-speed={speed}>
  <div class="logo-marquee-track">
    {
      duplicatedLogos.map((logo) => (
        <div class="logo-marquee-item">
          <img
            src={logo.src}
            alt={logo.alt}
            class="logo-marquee-image"
            loading="lazy"
          />
        </div>
      ))
    }
  </div>
</div>

<script>
  function initMarquee() {
    const containers = document.querySelectorAll(".logo-marquee-container");

    containers.forEach((container) => {
      const track = container.querySelector(
        ".logo-marquee-track"
      ) as HTMLElement;
      if (!track) return;

      const speed = Number(container.getAttribute("data-speed")) || 30;
      let currentSpeed = 1; // 1 = normal, 0.05 = almost stopped
      let targetSpeed = 1;
      let animationId: number;
      let position = 0;
      const trackWidth = track.scrollWidth / 2; // Half because we duplicated

      function animate() {
        // Smooth interpolation towards target speed
        currentSpeed += (targetSpeed - currentSpeed) * 0.05;

        // Calculate movement based on current speed
        const pixelsPerFrame = (trackWidth / (speed * 60)) * currentSpeed;
        position -= pixelsPerFrame;

        // Reset position for seamless loop
        if (Math.abs(position) >= trackWidth) {
          position = 0;
        }

        track.style.transform = `translateX(${position}px)`;
        animationId = requestAnimationFrame(animate);
      }

      // Start animation
      animate();

      // Slow down on hover
      container.addEventListener("mouseenter", () => {
        targetSpeed = 0.03; // Almost stopped
      });

      container.addEventListener("mouseleave", () => {
        targetSpeed = 1; // Resume normal speed
      });

      // Touch support for mobile
      container.addEventListener(
        "touchstart",
        () => {
          targetSpeed = 0.03;
        },
        { passive: true }
      );

      container.addEventListener("touchend", () => {
        targetSpeed = 1;
      });
    });
  }

  // Initialize on load and after view transitions
  initMarquee();
  document.addEventListener("astro:after-swap", initMarquee);
</script>

<style>
  .logo-marquee-container {
    width: 100%;
    max-width: 100vw; /* Prevent causing parent to expand */
    min-width: 0; /* Allow shrinking in flex/grid */
    overflow: hidden;
    padding-left: 1rem;
    padding-right: 1rem;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .logo-marquee-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    will-change: transform;
  }

  .logo-marquee-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.5rem;
  }

  .logo-marquee-image {
    height: 3rem;
    width: auto;
    max-width: 10rem;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .logo-marquee-item:hover .logo-marquee-image {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .logo-marquee-track {
      gap: 2rem;
    }

    .logo-marquee-item {
      padding: 0.75rem 1rem;
    }

    .logo-marquee-image {
      height: 2rem;
      max-width: 7rem;
    }
  }

  @media (max-width: 480px) {
    .logo-marquee-track {
      gap: 1.5rem;
    }

    .logo-marquee-image {
      height: 1.75rem;
      max-width: 6rem;
    }
  }
</style>
