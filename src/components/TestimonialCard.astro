---
import type { Testimonial } from "@/data/testimonials";

interface Props {
  testimonial: Testimonial;
  locale: string;
}

const { testimonial, locale } = Astro.props;

const title =
  testimonial.title[locale as keyof typeof testimonial.title] ||
  testimonial.title.tr;
const summary =
  testimonial.summary[locale as keyof typeof testimonial.summary] ||
  testimonial.summary.tr;

const detailHref =
  locale === "en"
    ? `/en/testimonials/${testimonial.slug}`
    : `/testimonials/${testimonial.slug}`;

const readMoreText = locale === "tr" ? "Devamını Oku" : "Read More";
---

<a
  href={detailHref}
  class="group block rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:border-gray-300 hover:shadow-md"
>
  <div class="flex items-start gap-4">
    <img
      src={testimonial.image}
      alt={testimonial.name}
      class="h-16 w-16 flex-shrink-0 rounded-full object-cover ring-2 ring-gray-100"
    />
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-gray-900">{testimonial.name}</h3>
      <p class="text-sm text-gray-500">{title}</p>
      <p class="text-sm text-gray-400">{testimonial.company}</p>
    </div>
  </div>

  <blockquote
    class="mt-4 text-gray-600 leading-relaxed break-words hyphens-auto"
  >
    "{summary}"
  </blockquote>

  <div
    class="mt-4 flex items-center text-sm font-medium text-gray-900 group-hover:text-gray-700"
  >
    {readMoreText}
    <svg
      class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </div>
</a>
