---
import NavigationMenu from "./nav/NavigationMenu.tsx";
import { getTranslations, localizeNavItems } from "../i18n/utils";

interface Props {
    locale: string;
    immersive?: boolean;
}

const { locale, immersive = false } = Astro.props;
const t = getTranslations(locale);
const pathname = Astro.url.pathname;
const navItems = localizeNavItems(t.nav.items, locale);

const trPath =
    locale === "en" ? pathname.replace(/^\/en/, "") || "/" : pathname;
const enPath = locale === "tr" ? `/en${pathname}` : pathname;
---

<header
    class:list={[
        "site-header fixed top-0 z-50 w-full transition-all duration-300",
        immersive ? "header-immersive" : "header-solid",
    ]}
    data-immersive={immersive}
>
    <div
        class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 py-1 md:h-20"
    >
        <!-- Logo -->
        <a href={locale === "tr" ? "/" : "/en/"} class="logo-link block">
            <img
                src="/hga-logo/hga-light.svg"
                alt="HGA"
                class="logo-light h-8 transition-opacity duration-300 md:h-10"
            />
            <img
                src="/hga-logo/hga-dark.svg"
                alt="HGA"
                class="logo-dark h-8 transition-opacity duration-300 md:h-10"
            />
        </a>

        <!-- Navigation -->
        <nav class="hidden md:flex">
            <NavigationMenu
                client:load
                items={navItems}
                currentPath={pathname}
            />
        </nav>

        <!-- Language Switcher (desktop) -->
        <div class="lang-switcher hidden items-center gap-3 md:flex">
            <a
                href={trPath}
                class:list={[
                    "text-sm font-medium transition-colors duration-300",
                    locale === "tr" ? "lang-active" : "lang-inactive",
                ]}
            >
                TR
            </a>
            <span class="lang-divider transition-colors duration-300">|</span>
            <a
                href={enPath}
                class:list={[
                    "text-sm font-medium transition-colors duration-300",
                    locale === "en" ? "lang-active" : "lang-inactive",
                ]}
            >
                EN
            </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
            class="mobile-menu-btn flex h-12 w-12 items-center justify-center rounded-lg transition-colors md:hidden"
            aria-label={locale === "tr" ? "Menüyü aç" : "Open menu"}
            aria-expanded="false"
        >
            <svg
                class="hamburger-icon h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
                class="close-icon hidden h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div
        class="mobile-menu pointer-events-none fixed inset-0 top-20 z-40 opacity-0 transition-opacity duration-300 md:hidden"
    >
        <div class="mobile-menu-backdrop absolute inset-0 bg-black/20"></div>
        <nav
            class="mobile-menu-content absolute inset-x-0 top-0 h-[calc(100vh-4rem)] translate-y-[-20px] overflow-y-auto bg-white p-6 transition-transform duration-300"
        >
            <ul class="space-y-1">
                {
                    navItems.map((item) => (
                        <li>
                            {item.children ? (
                                <div class="mobile-nav-group">
                                    <button
                                        class="mobile-nav-trigger flex w-full items-center justify-between rounded-lg px-4 py-3 text-left font-medium text-gray-900 hover:bg-gray-50"
                                        aria-expanded="false"
                                    >
                                        {item.title}
                                        <svg
                                            class="mobile-chevron h-5 w-5 text-gray-400 transition-transform"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M19 9l-7 7-7-7"
                                            />
                                        </svg>
                                    </button>
                                    <ul class="mobile-nav-children hidden space-y-1 pl-4 pt-1">
                                        {item.children.map((child) => (
                                            <li>
                                                <a
                                                    href={child.href}
                                                    class="block rounded-lg px-4 py-2 text-gray-600 hover:bg-gray-50 hover:text-gray-900"
                                                >
                                                    <span class="font-medium">
                                                        {child.title}
                                                    </span>
                                                    <p class="mt-0.5 text-sm text-gray-500">
                                                        {child.description}
                                                    </p>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            ) : (
                                <a
                                    href={item.href}
                                    class:list={[
                                        "block rounded-lg px-4 py-3 font-medium hover:bg-gray-50",
                                        pathname === item.href
                                            ? "bg-gray-100 text-gray-900"
                                            : "text-gray-600",
                                    ]}
                                >
                                    {item.title}
                                </a>
                            )}
                        </li>
                    ))
                }
            </ul>

            <!-- Language Switcher (mobile) -->
            <div
                class="mt-4 flex items-center gap-3 border-t border-gray-200 pt-4"
            >
                <a
                    href={trPath}
                    class:list={[
                        "rounded-lg px-4 py-2 text-sm font-medium transition-colors",
                        locale === "tr"
                            ? "bg-gray-900 text-white"
                            : "text-gray-600 hover:bg-gray-100",
                    ]}
                >
                    Türkçe
                </a>
                <a
                    href={enPath}
                    class:list={[
                        "rounded-lg px-4 py-2 text-sm font-medium transition-colors",
                        locale === "en"
                            ? "bg-gray-900 text-white"
                            : "text-gray-600 hover:bg-gray-100",
                    ]}
                >
                    English
                </a>
            </div>
        </nav>
    </div>
</header>

<style>
    /* Logo positioning */
    .logo-link {
        position: relative;
        display: flex;
        align-items: center;
        height: 32px;
    }

    @media (min-width: 768px) {
        .logo-link {
            height: 40px;
        }
    }

    .logo-dark {
        position: absolute;
        top: 0;
        left: 0;
    }

    /* Solid header (default for non-immersive pages) */
    .header-solid {
        background-color: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgb(229, 231, 235);
    }

    .header-solid .logo-light {
        opacity: 1;
    }

    .header-solid .logo-dark {
        opacity: 0;
    }

    .header-solid .lang-active {
        color: rgb(17, 24, 39);
    }

    .header-solid .lang-inactive {
        color: rgb(156, 163, 175);
    }

    .header-solid .lang-inactive:hover {
        color: rgb(55, 65, 81);
    }

    .header-solid .lang-divider {
        color: rgb(229, 231, 235);
    }

    .header-solid .mobile-menu-btn {
        color: rgb(55, 65, 81);
    }

    .header-solid .mobile-menu-btn:hover {
        background-color: rgb(243, 244, 246);
    }

    /* Immersive header (transparent over hero) */
    .header-immersive {
        background-color: transparent;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .header-immersive .logo-light {
        opacity: 0;
    }

    .header-immersive .logo-dark {
        opacity: 1;
    }

    .header-immersive .lang-active {
        color: white;
    }

    .header-immersive .lang-inactive {
        color: rgba(255, 255, 255, 0.6);
    }

    .header-immersive .lang-inactive:hover {
        color: rgba(255, 255, 255, 0.9);
    }

    .header-immersive .lang-divider {
        color: rgba(255, 255, 255, 0.3);
    }

    .header-immersive .mobile-menu-btn {
        color: white;
    }

    .header-immersive .mobile-menu-btn:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }

    /* Scrolled state (applied via JS) */
    .header-scrolled {
        background-color: rgba(255, 255, 255, 0.95) !important;
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgb(229, 231, 235) !important;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    }

    .header-scrolled .logo-light {
        opacity: 1 !important;
    }

    .header-scrolled .logo-dark {
        opacity: 0 !important;
    }

    .header-scrolled .lang-active {
        color: rgb(17, 24, 39) !important;
    }

    .header-scrolled .lang-inactive {
        color: rgb(156, 163, 175) !important;
    }

    .header-scrolled .lang-inactive:hover {
        color: rgb(55, 65, 81) !important;
    }

    .header-scrolled .lang-divider {
        color: rgb(229, 231, 235) !important;
    }

    .header-scrolled .mobile-menu-btn {
        color: rgb(55, 65, 81) !important;
    }

    .header-scrolled .mobile-menu-btn:hover {
        background-color: rgb(243, 244, 246) !important;
    }

    /* Mobile menu open state */
    .mobile-menu.is-open {
        opacity: 1;
        pointer-events: auto;
    }

    .mobile-menu.is-open .mobile-menu-content {
        transform: translateY(0);
    }

    .mobile-menu-btn.is-open .hamburger-icon {
        display: none;
    }

    .mobile-menu-btn.is-open .close-icon {
        display: block;
    }

    /* Header solid when menu is open */
    .site-header.menu-open {
        background-color: rgba(255, 255, 255, 0.98) !important;
        backdrop-filter: blur(12px) !important;
        border-bottom-color: rgb(229, 231, 235) !important;
    }

    .site-header.menu-open .logo-light {
        opacity: 1 !important;
    }

    .site-header.menu-open .logo-dark {
        opacity: 0 !important;
    }

    .site-header.menu-open .mobile-menu-btn {
        color: rgb(55, 65, 81) !important;
    }

    /* Mobile nav group expanded */
    .mobile-nav-group.is-expanded .mobile-chevron {
        transform: rotate(180deg);
    }

    .mobile-nav-group.is-expanded .mobile-nav-children {
        display: block;
    }

    /* Navigation Menu - Solid (default) */
    .header-solid :global(.nav-list) {
        border-color: rgb(243, 244, 246);
        background-color: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(4px);
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }

    .header-solid :global(.nav-trigger),
    .header-solid :global(.nav-link) {
        color: rgb(75, 85, 99);
    }

    .header-solid :global(.nav-trigger:hover),
    .header-solid :global(.nav-link:hover) {
        background-color: rgb(243, 244, 246);
        color: rgb(17, 24, 39);
    }

    .header-solid :global(.nav-link-active) {
        background-color: rgb(243, 244, 246);
        color: rgb(17, 24, 39);
    }

    .header-solid :global(.nav-chevron) {
        color: rgb(156, 163, 175);
    }

    /* Navigation Menu - Immersive */
    .header-immersive :global(.nav-list) {
        border-color: rgba(255, 255, 255, 0.15);
        background-color: rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(8px);
        box-shadow: none;
    }

    .header-immersive :global(.nav-trigger),
    .header-immersive :global(.nav-link) {
        color: rgba(255, 255, 255, 0.9);
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
    }

    .header-immersive :global(.nav-trigger:hover),
    .header-immersive :global(.nav-link:hover) {
        background-color: rgba(255, 255, 255, 0.1);
        color: white;
    }

    .header-immersive :global(.nav-link-active) {
        background-color: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .header-immersive :global(.nav-chevron) {
        color: rgba(255, 255, 255, 0.6);
    }

    /* Navigation Menu - Scrolled */
    .header-scrolled :global(.nav-list) {
        border-color: rgb(243, 244, 246) !important;
        background-color: rgba(255, 255, 255, 0.6) !important;
        backdrop-filter: blur(4px) !important;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05) !important;
    }

    .header-scrolled :global(.nav-trigger),
    .header-scrolled :global(.nav-link) {
        color: rgb(75, 85, 99) !important;
        text-shadow: none !important;
    }

    .header-scrolled :global(.nav-trigger:hover),
    .header-scrolled :global(.nav-link:hover) {
        background-color: rgb(243, 244, 246) !important;
        color: rgb(17, 24, 39) !important;
    }

    .header-scrolled :global(.nav-link-active) {
        background-color: rgb(243, 244, 246) !important;
        color: rgb(17, 24, 39) !important;
    }

    .header-scrolled :global(.nav-chevron) {
        color: rgb(156, 163, 175) !important;
    }
</style>

<script>
    function initHeader() {
        const header = document.querySelector(".site-header") as HTMLElement;
        if (!header) return;

        const isImmersive = header.dataset.immersive === "true";
        if (!isImmersive) return;

        const scrollThreshold = 100;

        function updateHeader() {
            if (window.scrollY > scrollThreshold) {
                header.classList.add("header-scrolled");
            } else {
                header.classList.remove("header-scrolled");
            }
        }

        // Initial check
        updateHeader();

        // Throttled scroll handler
        let ticking = false;
        window.addEventListener(
            "scroll",
            () => {
                if (!ticking) {
                    window.requestAnimationFrame(() => {
                        updateHeader();
                        ticking = false;
                    });
                    ticking = true;
                }
            },
            { passive: true },
        );
    }

    function initMobileMenu() {
        const header = document.querySelector(".site-header");
        const menuBtn = document.querySelector(".mobile-menu-btn");
        const mobileMenu = document.querySelector(".mobile-menu");
        const backdrop = document.querySelector(".mobile-menu-backdrop");
        const navGroups = document.querySelectorAll(".mobile-nav-group");

        if (!menuBtn || !mobileMenu || !header) return;

        function openMenu() {
            mobileMenu.classList.add("is-open");
            menuBtn.classList.add("is-open");
            header.classList.add("menu-open");
            menuBtn.setAttribute("aria-expanded", "true");
            document.body.style.overflow = "hidden";
        }

        function closeMenu() {
            mobileMenu.classList.remove("is-open");
            menuBtn.classList.remove("is-open");
            header.classList.remove("menu-open");
            menuBtn.setAttribute("aria-expanded", "false");
            document.body.style.overflow = "";
        }

        // Toggle mobile menu
        menuBtn.addEventListener("click", () => {
            const isOpen = mobileMenu.classList.contains("is-open");
            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        // Close on backdrop click
        backdrop?.addEventListener("click", closeMenu);

        // Handle nav group accordions
        navGroups.forEach((group) => {
            const trigger = group.querySelector(".mobile-nav-trigger");
            trigger?.addEventListener("click", () => {
                const isExpanded = group.classList.toggle("is-expanded");
                trigger.setAttribute("aria-expanded", String(isExpanded));
            });
        });

        // Close menu on link click
        const mobileLinks = mobileMenu.querySelectorAll("a");
        mobileLinks.forEach((link) => {
            link.addEventListener("click", closeMenu);
        });
    }

    // Initialize on DOM ready
    document.addEventListener("DOMContentLoaded", () => {
        initHeader();
        initMobileMenu();
    });

    // Handle Astro page transitions
    document.addEventListener("astro:page-load", () => {
        initHeader();
        initMobileMenu();
    });
</script>
